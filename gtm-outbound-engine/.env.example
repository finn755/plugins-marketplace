# GTM Outbound Engine — API Key Configuration
#
# Copy this file to .env and fill in your actual keys
# NOTE: .env files are local to your computer. Never commit them to git.
# Never share your .env file with others or post it publicly.

# REQUIRED: Choose one of these three
# Free option #1: Tavly (general B2B search)
TAVLY_API_KEY=your_tavly_api_key_here

# Free option #2: Exa (semantic search for niches)
EXA_API_KEY=your_exa_api_key_here

# Premium option: Supadata (website scraping + enrichment)
# NOTE: We have extra credits allocated. No setup needed unless you want to use your own key.
SUPADATA_API_KEY=your_supadata_api_key_here

# OPTIONAL: These are v2 features (not yet implemented)
# For v1, export CSVs manually to these platforms
INSTANTLY_API_KEY=your_instantly_api_key_here
LEMLIST_API_KEY=your_lemlist_api_key_here
HUBSPOT_API_KEY=your_hubspot_api_key_here

# OPTIONAL: Apollo.io enrichment
APOLLO_API_KEY=your_apollo_api_key_here

# Notion (usually connected via Cowork, but can be stored here)
NOTION_API_KEY=your_notion_api_key_here
